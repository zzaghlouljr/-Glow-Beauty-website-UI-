<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glow Beauty</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">🌸 Glow Beauty</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#products">Products</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero" id="home">
        <div class="hero-content">
            <h1>Feel Beautiful,<br>Feel Confident</h1>
            <p>Discover our premium collection of cosmetics crafted just for you</p>
            <a href="#products" class="btn">Shop Now</a>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section class="about" id="about">
        <div class="about-content">
            <h2>About Us</h2>
            <p>At Glow Beauty, we believe every person deserves to feel their best. Our products are made with
            natural ingredients, cruelty-free, and designed to enhance your natural beauty. We are committed
            to quality, elegance, and most importantly — you.</p>
        </div>
    </section>

    <!-- PRODUCTS SECTION -->
    <section class="products" id="products">
        <h2>Our Products</h2>
        <div class="product-grid">

            <div class="product-card">
                <div class="product-img">💄</div>
                <h3>Velvet Lipstick</h3>
                <p>Long-lasting, rich color for every occasion</p>
                <span class="price">$19.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="product-img">✨</div>
                <h3>Glow Foundation</h3>
                <p>Lightweight formula for a flawless finish</p>
                <span class="price">$34.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="product-img">👁️</div>
                <h3>Smoky Eye Palette</h3>
                <p>12 stunning shades for the perfect look</p>
                <span class="price">$29.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="product-img">🌿</div>
                <h3>Natural Face Serum</h3>
                <p>Nourish and hydrate your skin naturally</p>
                <span class="price">$44.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="product-img">🧴</div>
                <h3>Rose Moisturizer</h3>
                <p>24-hour hydration with a rose scent</p>
                <span class="price">$24.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="product-img">💅</div>
                <h3>Nail Polish Set</h3>
                <p>6 trendy colors for a perfect manicure</p>
                <span class="price">$14.99</span>
                <a href="#" class="btn-card">Add to Cart</a>
            </div>

        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact" id="contact">
        <h2>Contact Us</h2>
        <form class="contact-form">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea rows="5" placeholder="Your Message" required></textarea>
            <button type="submit" class="btn">Send Message</button>
        </form>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <p>© 2024 Glow Beauty. All rights reserved. Made with 🌸</p>
    </footer>

</body>
</html>
